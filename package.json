{
  "name": "music-service",
  "version": "0.1.0",
  "description": "Audio streaming backend — local filesystem library indexing, metadata, streaming, playlists",
  "type": "module",
  "main": "dist/boot.js",
  "scripts": {
    "start": "node dist/boot.js",
    "dev": "tsx watch src/boot.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "deploy": "bash deploy.sh",
    "deploy:dry": "bash deploy.sh --dry-run"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@rodrigo-barraza/service-library": "github:rodrigo-barraza/service-library",
    "@rodrigo-barraza/utilities-library": "github:rodrigo-barraza/utilities-library",
    "express": "^5.2.1",
    "luxon": "^3.7.2",
    "minio": "^8.0.7",
    "mongodb": "^7.2.0",
    "music-metadata": "^10.8.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/express": "^5.0.6",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.9.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.33.0",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@11.8.0"
}
